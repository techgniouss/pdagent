# Pocket Desk Agent - configuration template
# -------------------------------------------------
# NOTE: For new installs, run 'pdagent configure' instead of editing
# this file manually. The wizard creates ~/.pdagent/config and
# ~/.pdagent/credentials with proper structure and permissions.
#
# This file is kept for backward compatibility and advanced users
# who prefer environment variables or a flat .env file.
# -------------------------------------------------

# === Telegram ===
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_BOT_USERNAME=your_bot_username

# Comma-separated Telegram user IDs allowed to use this bot.
# Find your ID by messaging @userinfobot on Telegram.
AUTHORIZED_USER_IDS=123456789,987654321
# Legacy alias (still accepted): ALLOWED_USERS=123456789,987654321

# === Gemini AI Authentication ===
# Choose ONE authentication method via GEMINI_AUTH_MODE:
#
# Option 1 - Antigravity OAuth (default):
#   Uses the internal Google API. The project is usually auto-fetched.
#   If auto-detection fails, set GOOGLE_PROJECT_ID manually.
GEMINI_AUTH_MODE=antigravity
GOOGLE_OAUTH_ENABLED=true
#
# Option 2 - Gemini CLI OAuth (public API, no GCP project needed):
#   Uses the same OAuth flow as the official Gemini CLI.
# GEMINI_AUTH_MODE=gemini-cli
# GOOGLE_OAUTH_ENABLED=true
#
# Option 3 - Google API Key:
# GEMINI_AUTH_MODE=apikey
# GOOGLE_OAUTH_ENABLED=false
# GOOGLE_API_KEY=your_gemini_api_key_here
#
# Legacy alias (still accepted): ANTIGRAVITY_ENABLED=true

# === AI Model Settings ===
GEMINI_MODEL=gemini-2.0-flash
MAX_TOKENS_PER_REQUEST=8000
# SYSTEM_PROMPT="You are a helpful AI assistant."
# Legacy alias (still accepted): SYSTEM_INSTRUCTION=

# Optional: manually override the Google Cloud project ID for Antigravity OAuth
# GOOGLE_PROJECT_ID=your-project-id
# Legacy alias (still accepted): ANTIGRAVITY_PROJECT_ID=your-project-id

# === Security ===
# Comma-separated directories this bot may read/write.
APPROVED_DIRECTORIES=/path/to/your/projects

# === Claude Desktop Integration ===
# Default repository root used by /clauderepo and related commands.
CLAUDE_DEFAULT_REPO_PATH=
# Legacy alias (still accepted): DEFAULT_REPO_PATH=

# === File Upload Settings ===
# How long uploaded files stay on server before auto-delete.
# Options: 1h, 12h, 24h, 72h (default: 1h)
UPLOAD_EXPIRY_TIME=1h

# Dropbox token for large file uploads (optional).
# Get a token from: https://www.dropbox.com/developers/apps
# DROPBOX_ACCESS_TOKEN=your_dropbox_access_token_here

# === Auto-Update ===
# Set to false to disable periodic update checks.
AUTO_UPDATE_ENABLED=true
# Legacy alias (still accepted): AUTO_UPDATE_CHECK=true
AUTO_UPDATE_INTERVAL_MINUTES=60

# === Logging ===
LOG_LEVEL=INFO
